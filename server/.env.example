# Supabase Postgres connection string.
# Supabase dashboard -> Project Settings -> Database -> Connection string -> "URI" (use the pooled/"Transaction" one for Render).
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Any long random string. Generate one with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string

# Password for the platform-team System Admin screen (not customer-facing).
# Generate a bcrypt hash for this with: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))"
SYSTEM_ADMIN_PASSWORD_HASH=replace-with-a-bcrypt-hash

# Comma-separated list of every frontend origin: customer-admin, system-admin, marketing,
# staff, and customer (plus your Render URLs for all five, once deployed).
# customer-admin :5173  system-admin :5174  marketing :5175  staff :5176  customer :5177
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177

PORT=4000
