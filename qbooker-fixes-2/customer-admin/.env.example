# URL of your deployed (or local) QBooker API service.
VITE_API_URL=http://localhost:4000

# URL of the qbooker-marketing app — linked to from the header ("New here? Sign up").
VITE_MARKETING_URL=http://localhost:5175

# URL of the qbooker-staff app — shown to you so you can share it with your team.
VITE_STAFF_APP_URL=http://localhost:5176

# URL of the qbooker-customer app — used to build the shareable customer link.
VITE_CUSTOMER_APP_URL=http://localhost:5177

# Your shared WhatsApp Business number (once you have one), digits only or with a leading +.
# Used to build the wa.me links shown against each location. A placeholder is fine until
# you have a real number — the links just won't work yet.
VITE_WHATSAPP_NUMBER=+447000000000
